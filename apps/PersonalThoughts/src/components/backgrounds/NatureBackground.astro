---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const leafCount = {
  low: 10,
  medium: 25,
  high: 40,
};
---

<div class="nature-background">
  <div class="sky-gradient"></div>
  <div class="forest-layer"></div>
  <div class="leaves-container">
    {Array.from({ length: leafCount[intensity] }).map((_, i) => (
      <div
        class="leaf"
        style={{
          '--delay': `${Math.random() * 15}s`,
          '--duration': `${10 + Math.random() * 10}s`,
          '--x': `${Math.random() * 100}%`,
          '--size': `${15 + Math.random() * 20}px`,
          '--rotation': `${Math.random() * 360}deg`,
          '--sway': `${30 + Math.random() * 50}px`,
        }}
      >
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z" />
        </svg>
      </div>
    ))}
  </div>
  <div class="grass-container">
    {Array.from({ length: 50 }).map((_, i) => (
      <div
        class="grass"
        style={{
          '--x': `${i * 2}%`,
          '--height': `${20 + Math.random() * 30}px`,
          '--delay': `${Math.random() * 2}s`,
        }}
      />
    ))}
  </div>
  <div class="fireflies">
    {Array.from({ length: 15 }).map((_, i) => (
      <div
        class="firefly"
        style={{
          '--delay': `${Math.random() * 10}s`,
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .nature-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #87CEEB 0%, #98FB98 30%, #228B22 100%);
  }

  .sky-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 10%, rgba(255, 255, 200, 0.5) 0%, transparent 50%);
    animation: skyShift 30s ease-in-out infinite;
  }

  @keyframes skyShift {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .forest-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(180deg, transparent 0%, rgba(34, 139, 34, 0.3) 50%, rgba(0, 100, 0, 0.5) 100%);
  }

  .leaves-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .leaf {
    position: absolute;
    left: var(--x);
    top: -30px;
    width: var(--size);
    height: var(--size);
    color: rgba(46, 204, 113, 0.7);
    animation: falling var(--duration) linear var(--delay) infinite;
  }

  .leaf svg {
    width: 100%;
    height: 100%;
    animation: rotateLeaf 4s ease-in-out infinite;
  }

  @keyframes falling {
    0% {
      transform: translateY(-30px) translateX(0) rotate(var(--rotation));
      opacity: 1;
    }
    100% {
      transform: translateY(100vh) translateX(var(--sway)) rotate(calc(var(--rotation) + 720deg));
      opacity: 0.3;
    }
  }

  @keyframes rotateLeaf {
    0%, 100% { transform: rotate(-15deg); }
    50% { transform: rotate(15deg); }
  }

  .grass-container {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    display: flex;
  }

  .grass {
    position: absolute;
    left: var(--x);
    bottom: 0;
    width: 3px;
    height: var(--height);
    background: linear-gradient(to top, #228B22, #90EE90);
    border-radius: 50% 50% 0 0;
    transform-origin: bottom center;
    animation: sway 2s ease-in-out var(--delay) infinite;
  }

  @keyframes sway {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
  }

  .fireflies {
    position: absolute;
    inset: 0;
  }

  .firefly {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 6px;
    height: 6px;
    background: radial-gradient(circle, #FFFF00 0%, transparent 70%);
    border-radius: 50%;
    animation: glow 3s ease-in-out var(--delay) infinite;
  }

  @keyframes glow {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.5); }
  }
</style>
