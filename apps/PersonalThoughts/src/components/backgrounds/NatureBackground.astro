---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const fireflyCount = {
  low: 20,
  medium: 40,
  high: 80,
};

const leafCount = {
  low: 5,
  medium: 10,
  high: 20,
};
---

<div class="nature-background">
  <div class="night-sky"></div>
  <div class="moon-glow"></div>
  <div class="forest-silhouette"></div>
  <div class="mist-layer"></div>
  
  <div class="fireflies">
    {Array.from({ length: fireflyCount[intensity] }).map((_, i) => (
      <div
        class="firefly"
        style={{
          '--delay': `${Math.random() * 15}s`,
          '--duration': `${8 + Math.random() * 12}s`,
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
          '--size': `${3 + Math.random() * 5}px`,
          '--glow-color': Math.random() > 0.5 ? '#ffd700' : '#90ff90',
        }}
      />
    ))}
  </div>
  
  <div class="falling-leaves">
    {Array.from({ length: leafCount[intensity] }).map((_, i) => (
      <div
        class="leaf"
        style={{
          '--delay': `${Math.random() * 20}s`,
          '--duration': `${10 + Math.random() * 10}s`,
          '--x': `${Math.random() * 100}%`,
          '--size': `${8 + Math.random() * 12}px`,
          '--rotation': `${Math.random() * 360}deg`,
        }}
      />
    ))}
  </div>
  
  <div class="water-ripple-container">
    {Array.from({ length: 3 }).map((_, i) => (
      <div
        class="water-ripple"
        style={{
          '--delay': `${i * 4}s`,
          '--x': `${20 + i * 30}%`,
          '--y': `${70 + Math.random() * 20}%`,
        }}
      />
    ))}
  </div>
  
  <div class="grass-container">
    {Array.from({ length: 150 }).map((_, i) => (
      <div
        class="grass-blade"
        style={{
          '--x': `${Math.random() * 100}%`,
          '--delay': `${Math.random() * 3}s`,
          '--height': `${20 + Math.random() * 60}px`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .nature-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, 
      #0a1f1a 0%, 
      #0d2914 30%, 
      #1a3d2e 60%, 
      #0f2518 100%
    );
  }

  .night-sky {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, 
      rgba(20, 60, 80, 0.3) 0%, 
      transparent 60%
    );
  }

  .moon-glow {
    position: absolute;
    top: 5%;
    right: 15%;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, 
      rgba(255, 255, 200, 0.15) 0%, 
      rgba(255, 255, 200, 0.05) 40%, 
      transparent 70%
    );
    border-radius: 50%;
    filter: blur(20px);
    animation: moonPulse 8s ease-in-out infinite;
  }

  @keyframes moonPulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  .forest-silhouette {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(180deg, 
      transparent 0%, 
      rgba(10, 30, 20, 0.8) 100%
    );
  }

  .mist-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, 
      transparent 0%, 
      rgba(100, 150, 120, 0.05) 50%,
      rgba(100, 150, 120, 0.1) 100%
    );
    animation: mistFloat 20s ease-in-out infinite;
  }

  @keyframes mistFloat {
    0%, 100% { transform: translateX(0); opacity: 0.6; }
    50% { transform: translateX(20px); opacity: 0.8; }
  }

  .fireflies {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .firefly {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: radial-gradient(circle, 
      var(--glow-color) 0%, 
      rgba(255, 215, 0, 0.5) 30%, 
      transparent 70%
    );
    border-radius: 50%;
    box-shadow: 
      0 0 10px var(--glow-color),
      0 0 20px var(--glow-color),
      0 0 30px rgba(255, 215, 0, 0.5);
    animation: fireflyFloat var(--duration) ease-in-out var(--delay) infinite;
  }

  @keyframes fireflyFloat {
    0%, 100% {
      transform: translate(0, 0) scale(0.5);
      opacity: 0;
    }
    10% {
      opacity: 1;
      transform: scale(1);
    }
    25% {
      transform: translate(30px, -40px) scale(1.2);
      opacity: 0.9;
    }
    50% {
      transform: translate(-20px, -60px) scale(0.8);
      opacity: 1;
    }
    75% {
      transform: translate(40px, -30px) scale(1.1);
      opacity: 0.8;
    }
    90% {
      opacity: 0.5;
      transform: scale(0.6);
    }
  }

  .falling-leaves {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .leaf {
    position: absolute;
    left: var(--x);
    top: -20px;
    width: var(--size);
    height: var(--size);
    background: linear-gradient(135deg, 
      #2d5016 0%, 
      #4a7c23 50%, 
      #3d6b1a 100%
    );
    border-radius: 0 50% 50% 50%;
    transform: rotate(var(--rotation));
    animation: leafFall var(--duration) linear var(--delay) infinite;
    opacity: 0.7;
  }

  @keyframes leafFall {
    0% {
      transform: translateY(0) translateX(0) rotate(0deg);
      opacity: 0;
    }
    10% { opacity: 0.7; }
    25% {
      transform: translateY(25vh) translateX(50px) rotate(90deg);
    }
    50% {
      transform: translateY(50vh) translateX(-30px) rotate(180deg);
    }
    75% {
      transform: translateY(75vh) translateX(40px) rotate(270deg);
    }
    100% {
      transform: translateY(100vh) translateX(20px) rotate(360deg);
      opacity: 0;
    }
  }

  .water-ripple-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .water-ripple {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 100px;
    height: 30px;
    border: 1px solid rgba(100, 180, 150, 0.3);
    border-radius: 50%;
    animation: rippleExpand 6s ease-out var(--delay) infinite;
  }

  @keyframes rippleExpand {
    0% {
      transform: scale(0.5);
      opacity: 0;
    }
    20% {
      opacity: 0.6;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  .grass-container {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    display: flex;
    align-items: flex-end;
    pointer-events: none;
  }

  .grass-blade {
    position: absolute;
    left: var(--x);
    bottom: 0;
    width: 3px;
    height: var(--height);
    background: linear-gradient(180deg, 
      #3d7a2e 0%, 
      #2d5a20 100%
    );
    border-radius: 50% 50% 0 0;
    transform-origin: bottom center;
    animation: grassSway 3s ease-in-out var(--delay) infinite;
  }

  @keyframes grassSway {
    0%, 100% { transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .firefly,
    .leaf,
    .water-ripple,
    .grass-blade,
    .moon-glow,
    .mist-layer {
      animation: none;
    }
  }
</style>
