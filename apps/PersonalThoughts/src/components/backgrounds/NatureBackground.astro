---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const particleCount = {
  low: 15,
  medium: 30,
  high: 50,
};
---

<div class="nature-background">
  <div class="gradient-base"></div>
  <div class="aurora-container">
    <div class="aurora aurora-1"></div>
    <div class="aurora aurora-2"></div>
    <div class="aurora aurora-3"></div>
  </div>
  <div class="particles">
    {Array.from({ length: particleCount[intensity] }).map((_, i) => (
      <div
        class="particle"
        style={{
          '--delay': `${Math.random() * 10}s`,
          '--duration': `${15 + Math.random() * 15}s`,
          '--x': `${Math.random() * 100}%`,
          '--size': `${2 + Math.random() * 4}px`,
        }}
      />
    ))}
  </div>
  <div class="wave-container">
    <div class="wave wave-1"></div>
    <div class="wave wave-2"></div>
    <div class="wave wave-3"></div>
  </div>
  <div class="flow-lines">
    {Array.from({ length: 5 }).map((_, i) => (
      <div
        class="flow-line"
        style={{
          '--delay': `${i * 3}s`,
          '--y': `${20 + i * 15}%`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .nature-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #0a1a15 0%, #0d2818 50%, #0a1a15 100%);
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(25, 250, 198, 0.1) 0%, transparent 50%),
                radial-gradient(ellipse at 0% 50%, rgba(19, 214, 170, 0.08) 0%, transparent 40%),
                radial-gradient(ellipse at 100% 50%, rgba(14, 163, 135, 0.08) 0%, transparent 40%);
  }

  .aurora-container {
    position: absolute;
    inset: 0;
    opacity: 0.6;
  }

  .aurora {
    position: absolute;
    width: 100%;
    height: 100%;
    filter: blur(100px);
    animation: auroraMove 20s ease-in-out infinite;
  }

  .aurora-1 {
    background: radial-gradient(ellipse at 30% 20%, rgba(25, 250, 198, 0.3), transparent 50%);
    animation-delay: 0s;
  }

  .aurora-2 {
    background: radial-gradient(ellipse at 70% 30%, rgba(19, 214, 170, 0.25), transparent 50%);
    animation-delay: -7s;
  }

  .aurora-3 {
    background: radial-gradient(ellipse at 50% 50%, rgba(14, 163, 135, 0.2), transparent 50%);
    animation-delay: -14s;
  }

  @keyframes auroraMove {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    25% { transform: translate(5%, -5%) scale(1.1); opacity: 0.8; }
    50% { transform: translate(-3%, 3%) scale(0.95); opacity: 0.5; }
    75% { transform: translate(4%, -2%) scale(1.05); opacity: 0.7; }
  }

  .particles {
    position: absolute;
    inset: 0;
  }

  .particle {
    position: absolute;
    left: var(--x);
    bottom: -10px;
    width: var(--size);
    height: var(--size);
    background: radial-gradient(circle, rgba(25, 250, 198, 0.8), transparent);
    border-radius: 50%;
    animation: rise var(--duration) linear var(--delay) infinite;
  }

  @keyframes rise {
    0% {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    10% { opacity: 0.8; }
    90% { opacity: 0.8; }
    100% {
      transform: translateY(-100vh) translateX(30px);
      opacity: 0;
    }
  }

  .wave-container {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    overflow: hidden;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    background: linear-gradient(180deg, transparent 60%, rgba(25, 250, 198, 0.05) 100%);
    border-radius: 50% 50% 0 0;
    animation: waveMove 12s ease-in-out infinite;
  }

  .wave-1 {
    animation-delay: 0s;
    opacity: 0.5;
  }

  .wave-2 {
    animation-delay: -4s;
    opacity: 0.3;
    bottom: 10%;
  }

  .wave-3 {
    animation-delay: -8s;
    opacity: 0.2;
    bottom: 20%;
  }

  @keyframes waveMove {
    0%, 100% { transform: translateX(0) translateY(0); }
    50% { transform: translateX(2%) translateY(-5px); }
  }

  .flow-lines {
    position: absolute;
    inset: 0;
  }

  .flow-line {
    position: absolute;
    left: 0;
    top: var(--y);
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent, 
      rgba(25, 250, 198, 0.3), 
      rgba(19, 214, 170, 0.5), 
      rgba(25, 250, 198, 0.3), 
      transparent
    );
    animation: flowMove 8s ease-in-out var(--delay) infinite;
  }

  @keyframes flowMove {
    0%, 100% { 
      transform: translateX(-100%);
      opacity: 0;
    }
    50% { 
      transform: translateX(100%);
      opacity: 1;
    }
  }
</style>
