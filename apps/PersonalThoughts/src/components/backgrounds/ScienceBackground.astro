---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const starCount = {
  low: 50,
  medium: 100,
  high: 200,
};

const orbitCount = {
  low: 2,
  medium: 4,
  high: 6,
};
---

<div class="science-background">
  <div class="gradient-base"></div>
  <div class="nebula">
    <div class="nebula-layer nebula-1"></div>
    <div class="nebula-layer nebula-2"></div>
    <div class="nebula-layer nebula-3"></div>
  </div>
  <div class="stars">
    {Array.from({ length: starCount[intensity] }).map((_, i) => (
      <div
        class="star"
        style={{
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
          '--size': `${1 + Math.random() * 2}px`,
          '--delay': `${Math.random() * 5}s`,
          '--duration': `${2 + Math.random() * 3}s`,
        }}
      />
    ))}
  </div>
  <div class="orbits">
    {Array.from({ length: orbitCount[intensity] }).map((_, i) => (
      <div
        class="orbit"
        style={{
          '--size': `${100 + i * 60}px`,
          '--delay': `${i * 2}s`,
          '--direction': i % 2 === 0 ? 'normal' : 'reverse',
        }}
      >
        <div class="electron"></div>
      </div>
    ))}
  </div>
  <div class="atom-center">
    <div class="nucleus"></div>
  </div>
  <div class="shooting-stars">
    {Array.from({ length: 3 }).map((_, i) => (
      <div
        class="shooting-star"
        style={{
          '--delay': `${i * 5}s`,
          '--x': `${20 + i * 25}%`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .science-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #1c2433 0%, #151c28 50%, #1c2433 100%);
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(100, 120, 180, 0.03) 0%, transparent 60%);
  }

  .nebula {
    position: absolute;
    inset: 0;
    opacity: 0.3;
  }

  .nebula-layer {
    position: absolute;
    width: 100%;
    height: 100%;
    filter: blur(80px);
    animation: nebulaRotate 60s linear infinite;
  }

  .nebula-1 {
    background: radial-gradient(ellipse at 30% 40%, rgba(100, 110, 140, 0.12), transparent 50%);
    animation-delay: 0s;
  }

  .nebula-2 {
    background: radial-gradient(ellipse at 70% 60%, rgba(90, 100, 130, 0.1), transparent 50%);
    animation-delay: -20s;
  }

  .nebula-3 {
    background: radial-gradient(ellipse at 50% 50%, rgba(110, 120, 150, 0.08), transparent 50%);
    animation-delay: -40s;
  }

  @keyframes nebulaRotate {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  .stars {
    position: absolute;
    inset: 0;
  }

  .star {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: #fff;
    border-radius: 50%;
    animation: starTwinkle var(--duration) ease-in-out var(--delay) infinite;
  }

  @keyframes starTwinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .orbits {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--size);
    height: var(--size);
    border: 1px solid rgba(140, 150, 180, 0.2);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: orbitRotate 10s linear var(--delay) infinite;
    animation-direction: var(--direction);
  }

  .electron {
    position: absolute;
    top: -3px;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    background: radial-gradient(circle, rgba(180, 190, 220, 0.9), transparent);
    border-radius: 50%;
  }

  @keyframes orbitRotate {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .atom-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .nucleus {
    width: 12px;
    height: 12px;
    background: radial-gradient(circle, rgba(200, 210, 240, 0.9), rgba(150, 160, 190, 0.5));
    border-radius: 50%;
    animation: nucleusPulse 2s ease-in-out infinite;
  }

  @keyframes nucleusPulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  .shooting-stars {
    position: absolute;
    inset: 0;
  }

  .shooting-star {
    position: absolute;
    left: var(--x);
    top: 0;
    width: 100px;
    height: 1px;
    background: linear-gradient(90deg, rgba(200, 210, 240, 0.9), transparent);
    transform: rotate(45deg);
    animation: shootingStarMove 8s ease-out var(--delay) infinite;
  }

  @keyframes shootingStarMove {
    0% {
      transform: translateX(-100px) translateY(-100px) rotate(45deg);
      opacity: 0;
    }
    10% { opacity: 1; }
    30% {
      transform: translateX(300px) translateY(300px) rotate(45deg);
      opacity: 0;
    }
    100% { opacity: 0; }
  }
</style>
