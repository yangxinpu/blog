---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const particleCount = {
  low: 15,
  medium: 30,
  high: 50,
};
---

<div class="warm-background">
  <div class="gradient-layer"></div>
  <div class="glow-container">
    {Array.from({ length: particleCount[intensity] }).map((_, i) => (
      <div
        class="glow-particle"
        style={{
          '--delay': `${Math.random() * 10}s`,
          '--duration': `${8 + Math.random() * 12}s`,
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
          '--size': `${10 + Math.random() * 30}px`,
          '--opacity': `${0.3 + Math.random() * 0.4}`,
        }}
      />
    ))}
  </div>
  <div class="sun-rays"></div>
</div>

<style>
  .warm-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(135deg, #FFF5F5 0%, #FFE4E1 25%, #FFDAB9 50%, #FFE4B5 75%, #FFF8DC 100%);
  }

  .gradient-layer {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(255, 107, 107, 0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(255, 230, 109, 0.3) 0%, transparent 50%);
    animation: gradientShift 20s ease-in-out infinite;
  }

  @keyframes gradientShift {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }

  .glow-container {
    position: absolute;
    inset: 0;
  }

  .glow-particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    background: radial-gradient(circle, rgba(255, 183, 77, var(--opacity)) 0%, transparent 70%);
    border-radius: 50%;
    animation: floatGlow var(--duration) ease-in-out var(--delay) infinite;
  }

  @keyframes floatGlow {
    0%, 100% {
      transform: translate(0, 0) scale(1);
      opacity: var(--opacity);
    }
    25% {
      transform: translate(20px, -30px) scale(1.2);
    }
    50% {
      transform: translate(-10px, -50px) scale(0.8);
      opacity: calc(var(--opacity) * 0.5);
    }
    75% {
      transform: translate(30px, -20px) scale(1.1);
    }
  }

  .sun-rays {
    position: absolute;
    top: -50%;
    left: 50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      rgba(255, 200, 100, 0.1) 10deg,
      transparent 20deg,
      transparent 30deg,
      rgba(255, 200, 100, 0.1) 40deg,
      transparent 50deg
    );
    transform: translateX(-50%);
    animation: rotateSun 60s linear infinite;
  }

  @keyframes rotateSun {
    from { transform: translateX(-50%) rotate(0deg); }
    to { transform: translateX(-50%) rotate(360deg); }
  }
</style>
