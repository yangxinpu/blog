---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const cellCount = {
  low: 8,
  medium: 15,
  high: 25,
};

const dnaCount = {
  low: 2,
  medium: 4,
  high: 6,
};
---

<div class="life-background">
  <div class="gradient-base"></div>
  <div class="dna-helix">
    {Array.from({ length: dnaCount[intensity] }).map((_, i) => (
      <div
        class="dna-strand"
        style={{
          '--x': `${15 + i * 20}%`,
          '--delay': `${i * 2}s`,
          '--direction': i % 2 === 0 ? 'normal' : 'reverse',
        }}
      >
        <div class="strand-line strand-line-1"></div>
        <div class="strand-line strand-line-2"></div>
        {Array.from({ length: 8 }).map((_, j) => (
          <div
            class="dna-node"
            style={{
              '--node-delay': `${j * 0.3}s`,
              '--node-y': `${j * 12.5}%`,
            }}
          />
        ))}
      </div>
    ))}
  </div>
  <div class="cells">
    {Array.from({ length: cellCount[intensity] }).map((_, i) => (
      <div
        class="cell"
        style={{
          '--delay': `${Math.random() * 10}s`,
          '--duration': `${20 + Math.random() * 20}s`,
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
          '--size': `${30 + Math.random() * 50}px`,
        }}
      >
        <div class="cell-nucleus"></div>
      </div>
    ))}
  </div>
  <div class="pulse-rings">
    {Array.from({ length: 3 }).map((_, i) => (
      <div
        class="pulse-ring"
        style={{
          '--delay': `${i * 4}s`,
        }}
      />
    ))}
  </div>
  <div class="energy-lines">
    {Array.from({ length: 8 }).map((_, i) => (
      <div
        class="energy-line"
        style={{
          '--angle': `${i * 45}deg`,
          '--delay': `${i * 0.5}s`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .life-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #0a1512 0%, #0d1f1a 50%, #0a1512 100%);
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(19, 214, 170, 0.1) 0%, transparent 60%);
  }

  .dna-helix {
    position: absolute;
    inset: 0;
    opacity: 0.4;
  }

  .dna-strand {
    position: absolute;
    left: var(--x);
    top: 0;
    width: 2px;
    height: 100%;
    animation: dnaRotate 10s linear var(--delay) infinite;
    animation-direction: var(--direction);
  }

  .strand-line {
    position: absolute;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, 
      transparent 0%, 
      rgba(19, 214, 170, 0.5) 25%, 
      transparent 50%,
      rgba(14, 163, 135, 0.5) 75%,
      transparent 100%
    );
  }

  .strand-line-1 {
    animation: strandMove1 4s ease-in-out infinite;
  }

  .strand-line-2 {
    animation: strandMove2 4s ease-in-out infinite;
  }

  @keyframes strandMove1 {
    0%, 100% { transform: translateX(-15px); }
    50% { transform: translateX(15px); }
  }

  @keyframes strandMove2 {
    0%, 100% { transform: translateX(15px); }
    50% { transform: translateX(-15px); }
  }

  .dna-node {
    position: absolute;
    top: var(--node-y);
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    background: radial-gradient(circle, rgba(19, 214, 170, 0.8), transparent);
    border-radius: 50%;
    animation: nodePulse 2s ease-in-out var(--node-delay) infinite;
  }

  @keyframes nodePulse {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.8; }
    50% { transform: translateX(-50%) scale(1.5); opacity: 0.4; }
  }

  .cells {
    position: absolute;
    inset: 0;
  }

  .cell {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border: 1px solid rgba(19, 214, 170, 0.3);
    border-radius: 50%;
    animation: cellFloat var(--duration) ease-in-out var(--delay) infinite;
  }

  .cell-nucleus {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40%;
    height: 40%;
    background: radial-gradient(circle, rgba(19, 214, 170, 0.4), transparent);
    border-radius: 50%;
    animation: nucleusPulse 3s ease-in-out infinite;
  }

  @keyframes cellFloat {
    0%, 100% { 
      transform: translate(0, 0) rotate(0deg);
      opacity: 0.3;
    }
    25% { 
      transform: translate(20px, -20px) rotate(90deg);
      opacity: 0.5;
    }
    50% { 
      transform: translate(0, -40px) rotate(180deg);
      opacity: 0.3;
    }
    75% { 
      transform: translate(-20px, -20px) rotate(270deg);
      opacity: 0.5;
    }
  }

  @keyframes nucleusPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.2); }
  }

  .pulse-rings {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .pulse-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    border: 1px solid rgba(19, 214, 170, 0.3);
    border-radius: 50%;
    animation: pulseExpand 8s ease-out var(--delay) infinite;
  }

  @keyframes pulseExpand {
    0% {
      width: 100px;
      height: 100px;
      opacity: 0.5;
    }
    100% {
      width: 800px;
      height: 800px;
      opacity: 0;
    }
  }

  .energy-lines {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .energy-line {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 300px;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent, 
      rgba(19, 214, 170, 0.5), 
      rgba(14, 163, 135, 0.8), 
      rgba(19, 214, 170, 0.5), 
      transparent
    );
    transform-origin: left center;
    transform: rotate(var(--angle));
    animation: energyFlow 4s ease-in-out var(--delay) infinite;
  }

  @keyframes energyFlow {
    0%, 100% { 
      opacity: 0;
      transform: rotate(var(--angle)) scaleX(0.3);
    }
    50% { 
      opacity: 0.6;
      transform: rotate(var(--angle)) scaleX(1);
    }
  }
</style>
