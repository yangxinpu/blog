---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const crackCount = {
  low: 3,
  medium: 6,
  high: 10,
};
---

<div class="resilience-background">
  <div class="gradient-base"></div>
  <div class="rock-texture"></div>
  <div class="cracks">
    {Array.from({ length: crackCount[intensity] }).map((_, i) => (
      <div
        class="crack"
        style={{
          '--x': `${10 + Math.random() * 80}%`,
          '--y': `${10 + Math.random() * 80}%`,
          '--angle': `${Math.random() * 360}deg`,
          '--delay': `${i * 2}s`,
        }}
      />
    ))}
  </div>
  <div class="light-beams">
    {Array.from({ length: 5 }).map((_, i) => (
      <div
        class="beam"
        style={{
          '--x': `${i * 20 + 10}%`,
          '--delay': `${i * 3}s`,
        }}
      />
    ))}
  </div>
  <div class="particles">
    {Array.from({ length: 20 }).map((_, i) => (
      <div
        class="particle"
        style={{
          '--delay': `${Math.random() * 10}s`,
          '--duration': `${10 + Math.random() * 10}s`,
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
        }}
      />
    ))}
  </div>
</div>

<style>
  .resilience-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #0a0f0e 0%, #0d1513 50%, #0a0f0e 100%);
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(14, 163, 135, 0.08) 0%, transparent 60%);
  }

  .rock-texture {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(14, 163, 135, 0.03) 0%, transparent 20%),
      radial-gradient(circle at 80% 70%, rgba(10, 111, 93, 0.03) 0%, transparent 20%),
      radial-gradient(circle at 50% 50%, rgba(14, 163, 135, 0.02) 0%, transparent 30%);
    opacity: 0.8;
  }

  .cracks {
    position: absolute;
    inset: 0;
  }

  .crack {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 100px;
    height: 2px;
    background: linear-gradient(90deg, 
      transparent, 
      rgba(14, 163, 135, 0.4), 
      rgba(10, 111, 93, 0.6), 
      rgba(14, 163, 135, 0.4), 
      transparent
    );
    transform: rotate(var(--angle));
    animation: crackGlow 8s ease-in-out var(--delay) infinite;
  }

  .crack::before,
  .crack::after {
    content: '';
    position: absolute;
    width: 50px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(14, 163, 135, 0.3), transparent);
  }

  .crack::before {
    top: -10px;
    left: 20px;
    transform: rotate(30deg);
  }

  .crack::after {
    top: 10px;
    right: 20px;
    transform: rotate(-30deg);
  }

  @keyframes crackGlow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  .light-beams {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .beam {
    position: absolute;
    left: var(--x);
    top: -20%;
    width: 2px;
    height: 140%;
    background: linear-gradient(180deg, 
      transparent, 
      rgba(14, 163, 135, 0.1), 
      rgba(10, 111, 93, 0.2), 
      rgba(14, 163, 135, 0.1), 
      transparent
    );
    animation: beamPulse 10s ease-in-out var(--delay) infinite;
  }

  @keyframes beamPulse {
    0%, 100% { opacity: 0.2; transform: scaleY(1); }
    50% { opacity: 0.5; transform: scaleY(1.1); }
  }

  .particles {
    position: absolute;
    inset: 0;
  }

  .particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 2px;
    height: 2px;
    background: rgba(14, 163, 135, 0.6);
    border-radius: 50%;
    animation: particleFloat var(--duration) ease-in-out var(--delay) infinite;
  }

  @keyframes particleFloat {
    0%, 100% { 
      transform: translate(0, 0);
      opacity: 0.3;
    }
    50% { 
      transform: translate(10px, -20px);
      opacity: 0.8;
    }
  }
</style>
