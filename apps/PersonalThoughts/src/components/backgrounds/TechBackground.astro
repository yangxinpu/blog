---
export interface Props {
  intensity?: 'low' | 'medium' | 'high';
}

const { intensity = 'medium' } = Astro.props;

const matrixLines = {
  low: 10,
  medium: 20,
  high: 35,
};

const nodeCount = {
  low: 5,
  medium: 10,
  high: 20,
};
---

<div class="tech-background">
  <div class="gradient-base"></div>
  <div class="matrix-rain">
    {Array.from({ length: matrixLines[intensity] }).map((_, i) => (
      <div
        class="matrix-column"
        style={{
          '--x': `${(i / matrixLines[intensity]) * 100}%`,
          '--delay': `${Math.random() * 5}s`,
          '--duration': `${8 + Math.random() * 8}s`,
        }}
      >
        {Array.from({ length: 15 }).map((_, j) => (
          <span
            class="matrix-char"
            style={{
              '--char-delay': `${j * 0.1}s`,
            }}
          >
            {String.fromCharCode(0x30A0 + Math.random() * 96)}
          </span>
        ))}
      </div>
    ))}
  </div>
  <div class="circuit-lines">
    {Array.from({ length: 8 }).map((_, i) => (
      <div
        class="circuit-line"
        style={{
          '--y': `${10 + i * 12}%`,
          '--delay': `${i * 0.5}s`,
        }}
      />
    ))}
  </div>
  <div class="data-nodes">
    {Array.from({ length: nodeCount[intensity] }).map((_, i) => (
      <div
        class="node"
        style={{
          '--x': `${Math.random() * 100}%`,
          '--y': `${Math.random() * 100}%`,
          '--delay': `${Math.random() * 5}s`,
        }}
      >
        <div class="node-pulse"></div>
      </div>
    ))}
  </div>
</div>

<style>
  .tech-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(180deg, #0a192f 0%, #0d1f2d 50%, #0a192f 100%);
  }

  .gradient-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(10, 111, 93, 0.1) 0%, transparent 60%);
  }

  .matrix-rain {
    position: absolute;
    inset: 0;
    opacity: 0.3;
  }

  .matrix-column {
    position: absolute;
    left: var(--x);
    top: -100%;
    display: flex;
    flex-direction: column;
    animation: matrixFall var(--duration) linear var(--delay) infinite;
  }

  .matrix-char {
    font-family: monospace;
    font-size: 14px;
    color: rgba(10, 111, 93, 0.8);
    opacity: 0;
    animation: charFade 0.5s ease-out var(--char-delay) forwards;
  }

  @keyframes matrixFall {
    0% { transform: translateY(0); }
    100% { transform: translateY(200vh); }
  }

  @keyframes charFade {
    0% { opacity: 0; }
    20% { opacity: 1; }
    100% { opacity: 0; }
  }

  .circuit-lines {
    position: absolute;
    inset: 0;
  }

  .circuit-line {
    position: absolute;
    left: 0;
    top: var(--y);
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent, 
      rgba(10, 111, 93, 0.3), 
      rgba(25, 250, 198, 0.5), 
      rgba(10, 111, 93, 0.3), 
      transparent
    );
    animation: circuitPulse 4s ease-in-out var(--delay) infinite;
  }

  @keyframes circuitPulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.6; }
  }

  .data-nodes {
    position: absolute;
    inset: 0;
  }

  .node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 6px;
    height: 6px;
    background: rgba(10, 111, 93, 0.8);
    border-radius: 50%;
    animation: nodeGlow 3s ease-in-out var(--delay) infinite;
  }

  .node-pulse {
    position: absolute;
    inset: -10px;
    border: 1px solid rgba(10, 111, 93, 0.3);
    border-radius: 50%;
    animation: nodePulse 3s ease-out var(--delay) infinite;
  }

  @keyframes nodeGlow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @keyframes nodePulse {
    0% { transform: scale(1); opacity: 0.5; }
    100% { transform: scale(3); opacity: 0; }
  }
</style>
