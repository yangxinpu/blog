---
import BaseLayout from '../layouts/BaseLayout.astro';
import LifeBackground from '../components/backgrounds/LifeBackground.astro';

const thoughts = [
  {
    date: '2024年3月30日',
    title: '生命的律动',
    content: '每一个细胞都在跳动，每一次呼吸都是生命的礼赞。我们由无数微小的生命组成，它们共同谱写着存在的奇迹。'
  },
  {
    date: '2024年2月25日',
    title: '成长的轨迹',
    content: '生命不是一条直线，而是螺旋上升的阶梯。每一次回望，都发现自己已经站在更高的地方。成长，是生命最美的姿态。'
  },
  {
    date: '2024年1月20日',
    title: '传承的意义',
    content: 'DNA是时间的密码，将祖先的记忆传递给未来。我们承载着无数生命的期望，活出精彩，是对生命最好的致敬。'
  }
];
---

<BaseLayout title="生命 - 思想集" theme="life">
  <LifeBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">生命</h1>
    <p class="theme-subtitle">DNA的螺旋，细胞的律动，探索生命的奥秘与奇迹</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #9B59B6, #E74C3C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.8;
    max-width: 500px;
    margin: 0 auto;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(155, 89, 182, 0.3);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(155, 89, 182, 0.2);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    display: block;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #9B59B6;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.9;
  }
</style>
