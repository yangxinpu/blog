---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const themes = [
  { 
    id: 'nature', 
    name: '自然', 
    desc: '翠绿森林，流水潺潺', 
    color: '#19fac6',
    icon: 'leaf'
  },
  { 
    id: 'life', 
    name: '生命', 
    desc: 'DNA螺旋，细胞律动', 
    color: '#13d6aa',
    icon: 'dna'
  },
  { 
    id: 'resilience', 
    name: '坚韧', 
    desc: '岩石纹理，不屈力量', 
    color: '#0ea387',
    icon: 'mountain'
  },
  { 
    id: 'tech', 
    name: '技术', 
    desc: '代码矩阵，数据流动', 
    color: '#0a6f5d',
    icon: 'code'
  },
  { 
    id: 'science', 
    name: '科学', 
    desc: '浩瀚星空，原子轨迹', 
    color: '#19fac6',
    icon: 'atom'
  },
];
---

<BaseLayout title="思想集 - 个人感想">
  <div class="bg-animation">
    <div class="floating-orb orb-1"></div>
    <div class="floating-orb orb-2"></div>
    <div class="floating-orb orb-3"></div>
    <div class="grid-lines"></div>
  </div>
  
  <div class="hero">
    <h1 class="title">
      <span class="title-line">思想的</span>
      <span class="title-highlight">无限可能</span>
    </h1>
    <p class="subtitle">记录生活中的点滴感悟，探索内心深处的声音</p>
  </div>
  
  <div class="themes-container">
    <div class="themes-grid">
      {themes.map((theme, index) => (
        <a 
          href={`/${theme.id}`} 
          class="theme-card"
          style={`--theme-color: ${theme.color}; --delay: ${index * 0.1}s`}
        >
          <div class="card-glow"></div>
          <div class="card-content">
            <div class="theme-icon">
              <Icon name={theme.icon} size={32} strokeWidth={1.5} />
            </div>
            <div class="theme-info">
              <h3 class="theme-name">{theme.name}</h3>
              <p class="theme-desc">{theme.desc}</p>
            </div>
            <div class="card-arrow">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
          <div class="card-border"></div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  :root {
    --primary-100: #d3fff3;
    --primary-200: #97fce4;
    --primary-300: #19fac6;
    --primary-400: #13d6aa;
    --primary-500: #0ea387;
    --primary-600: #0a6f5d;
  }

  .bg-animation {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0a0a0a 100%);
    overflow: hidden;
  }

  .floating-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: float 20s ease-in-out infinite;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(25, 250, 198, 0.3), transparent);
    top: -10%;
    left: -10%;
    animation-delay: 0s;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(19, 214, 170, 0.2), transparent);
    bottom: -5%;
    right: -5%;
    animation-delay: -7s;
  }

  .orb-3 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(14, 163, 135, 0.25), transparent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -14s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(50px, -50px) scale(1.1); }
    50% { transform: translate(-30px, 30px) scale(0.95); }
    75% { transform: translate(40px, 20px) scale(1.05); }
  }

  .grid-lines {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(25, 250, 198, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(25, 250, 198, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridMove 30s linear infinite;
  }

  @keyframes gridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
  }

  .hero {
    text-align: center;
    margin-bottom: 4rem;
    position: relative;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(25, 250, 198, 0.1);
    border: 1px solid rgba(25, 250, 198, 0.3);
    border-radius: 50px;
    font-size: 0.875rem;
    color: var(--primary-300);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease-out;
  }

  .title {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 2rem;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }

  .title-line {
    color: #e0e0e0;
  }

  .title-highlight {
    background: linear-gradient(135deg, var(--primary-300), var(--primary-500));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #888;
    max-width: 500px;
    margin: 0 auto 2rem;
    animation: fadeInUp 0.8s ease-out 0.4s both;
  }

  .hero-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    animation: fadeInUp 0.8s ease-out 0.6s both;
  }

  .deco-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary-400));
  }

  .deco-line:last-child {
    background: linear-gradient(90deg, var(--primary-400), transparent);
  }

  .deco-dot {
    width: 8px;
    height: 8px;
    background: var(--primary-300);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .themes-container {
    width: 100%;
    max-width: 1000px;
  }

  .themes-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .theme-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    animation: fadeInUp 0.8s ease-out var(--delay) both;
    transition: transform 0.4s ease;
  }

  .theme-card:hover {
    transform: translateX(10px);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--theme-color), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .theme-card:hover .card-glow {
    opacity: 0.1;
  }

  .card-content {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    z-index: 1;
  }

  .theme-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(25, 250, 198, 0.1);
    border-radius: 12px;
    flex-shrink: 0;
    transition: transform 0.4s ease, background 0.4s ease;
    color: var(--primary-300);
  }

  .theme-card:hover .theme-icon {
    transform: scale(1.1) rotate(5deg);
    background: rgba(25, 250, 198, 0.2);
  }

  .theme-info {
    flex: 1;
  }

  .theme-name {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: #e0e0e0;
    transition: color 0.4s ease;
  }

  .theme-card:hover .theme-name {
    color: var(--theme-color);
  }

  .theme-desc {
    font-size: 0.95rem;
    color: #666;
    margin: 0;
  }

  .card-arrow {
    color: #444;
    transition: color 0.4s ease, transform 0.4s ease;
  }

  .theme-card:hover .card-arrow {
    color: var(--theme-color);
    transform: translateX(5px);
  }

  .card-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(135deg, var(--theme-color), transparent 50%);
    -webkit-mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    mask: 
      linear-gradient(#fff 0 0) content-box, 
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .theme-card:hover .card-border {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero {
      margin-bottom: 3rem;
    }

    .card-content {
      padding: 1.25rem 1.5rem;
      gap: 1rem;
    }

    .theme-icon {
      width: 50px;
      height: 50px;
    }

    .theme-name {
      font-size: 1.25rem;
    }

    .theme-card:hover {
      transform: none;
    }
  }
</style>
