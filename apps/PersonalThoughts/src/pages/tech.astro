---
import BaseLayout from '../layouts/BaseLayout.astro';
import TechBackground from '../components/backgrounds/TechBackground.astro';

const frontEndTechs = [
  { name: 'React', color: '#61DAFB', logo: 'https://cdn.simpleicons.org/react/61DAFB' },
  { name: 'Vue', color: '#42B883', logo: 'https://cdn.simpleicons.org/vuedotjs/42B883' },
  { name: 'Angular', color: '#DD0031', logo: 'https://cdn.simpleicons.org/angular/DD0031' },
  { name: 'TypeScript', color: '#3178C6', logo: 'https://cdn.simpleicons.org/typescript/3178C6' },
  { name: 'Next.js', color: '#000000', logo: 'https://cdn.simpleicons.org/nextdotjs/000000' },
  { name: 'Vite', color: '#646CFF', logo: 'https://cdn.simpleicons.org/vite/646CFF' },
  { name: 'Tailwind', color: '#06B6D4', logo: 'https://cdn.simpleicons.org/tailwindcss/06B6D4' },
  { name: 'Svelte', color: '#FF3E00', logo: 'https://cdn.simpleicons.org/svelte/FF3E00' },
  { name: 'Astro', color: '#FF5D01', logo: 'https://cdn.simpleicons.org/astro/FF5D01' },
  { name: 'Node.js', color: '#339933', logo: 'https://cdn.simpleicons.org/nodedotjs/339933' },
  { name: 'Linux', color: '#FCC624', logo: 'https://cdn.simpleicons.org/linux/FCC624' },
  { name: 'Webpack', color: '#8DD6F9', logo: 'https://cdn.simpleicons.org/webpack/8DD6F9' },
  { name: 'ESLint', color: '#4B32C3', logo: 'https://cdn.simpleicons.org/eslint/4B32C3' },
  { name: 'VitePress', color: '#646CFF', logo: 'https://cdn.simpleicons.org/vitepress/646CFF' },
  { name: 'Vitest', color: '#6E9F18', logo: 'https://cdn.simpleicons.org/vitest/6E9F18' },
];

const dataScienceTechs = [
  { name: 'Python', color: '#3776AB', logo: 'https://cdn.simpleicons.org/python/3776AB' },
  { name: 'NumPy', color: '#013243', logo: 'https://cdn.simpleicons.org/numpy/013243' },
  { name: 'Pandas', color: '#150458', logo: 'https://cdn.simpleicons.org/pandas/150458' },
  { name: 'TensorFlow', color: '#FF6F00', logo: 'https://cdn.simpleicons.org/tensorflow/FF6F00' },
  { name: 'PyTorch', color: '#EE4C2C', logo: 'https://cdn.simpleicons.org/pytorch/EE4C2C' },
  { name: 'Scikit-learn', color: '#F7931E', logo: 'https://cdn.simpleicons.org/scikitlearn/F7931E' },
  { name: 'Jupyter', color: '#F37626', logo: 'https://cdn.simpleicons.org/jupyter/F37626' },
  { name: 'R', color: '#276DC3', logo: 'https://cdn.simpleicons.org/r/276DC3' },
  { name: 'Docker', color: '#2496ED', logo: 'https://cdn.simpleicons.org/docker/2496ED' },
  { name: 'Git', color: '#F05032', logo: 'https://cdn.simpleicons.org/git/F05032' },
];

const allTechs = [...frontEndTechs, ...dataScienceTechs];

const thoughts = [
  {
    date: '2024年4月10日',
    title: '代码的诗意',
    content: '每一行代码都是一首诗，逻辑是它的韵脚，功能是它的意境。在0和1的世界里，我们创造着无限可能。技术，是人类智慧的结晶。'
  },
  {
    date: '2024年3月15日',
    title: '算法的艺术',
    content: '算法不只是解决问题的工具，更是一种思维方式。它教会我们如何分解复杂，如何寻找最优，如何在有限中创造无限。'
  },
  {
    date: '2024年2月10日',
    title: '开源的精神',
    content: '代码共享，智慧传承。开源不仅是技术，更是一种精神。在分享中成长，在协作中进步，这是技术社区最美的风景。'
  }
];

function getLogoPosition(index, total) {
  const isLeft = index % 2 === 0;
  const row = Math.floor(index / 2);
  const size = 55 + (index % 3) * 10;
  const leftColumns = [0, 8, 16, 24, 32];
  const rightColumns = [68, 76, 84, 72, 80];
  
  if (isLeft) {
    return {
      x: leftColumns[row % 5],
      y: 10 + row * 12,
      size,
    };
  } else {
    return {
      x: rightColumns[row % 5],
      y: 10 + row * 12,
      size,
    };
  }
}
---

<BaseLayout title="技术 - 思想集" theme="tech">
  <TechBackground slot="background" />
  
  <div class="tech-logos-container">
    {allTechs.map((tech, i) => {
      const pos = getLogoPosition(i, allTechs.length);
      return (
        <div
          class="tech-logo"
          style={{
            '--tech-color': tech.color,
            '--delay': `${i * 0.08}s`,
            '--x': `${pos.x}%`,
            '--y': `${pos.y}%`,
            '--size': `${pos.size}px`,
          }}
        >
          <img src={tech.logo} alt={tech.name} class="logo-image" />
        </div>
      );
    })}
  </div>
  
  <div class="theme-header">
    <h1 class="theme-title">技术</h1>
    <p class="theme-subtitle">代码的矩阵，数据的流动，探索技术的无限可能</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .tech-logos-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .tech-logo {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(4px);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    z-index: -1;
  }

  .tech-logo:hover {
    transform: scale(1.2) translateY(-5px);
    box-shadow: 0 10px 30px var(--tech-color);
    border-color: var(--tech-color);
    z-index: 5;
  }

  .logo-image {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
    z-index: 10;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #3178c6;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.7;
    max-width: 500px;
    margin: 0 auto;
    color: #888;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .thought-card {
    background: rgba(49, 120, 198, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(49, 120, 198, 0.2);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    z-index: 10;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(49, 120, 198, 0.15);
    border-color: rgba(49, 120, 198, 0.4);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    display: block;
    color: #888;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #3178c6;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.85;
    color: #b0b0b0;
  }
</style>
