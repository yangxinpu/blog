---
import BaseLayout from '../layouts/BaseLayout.astro';
import TechBackground from '../components/backgrounds/TechBackground.astro';

const thoughts = [
  {
    date: '2024年4月10日',
    title: '代码的诗意',
    content: '每一行代码都是一首诗，逻辑是它的韵脚，功能是它的意境。在0和1的世界里，我们创造着无限可能。技术，是人类智慧的结晶。'
  },
  {
    date: '2024年3月15日',
    title: '算法的艺术',
    content: '算法不只是解决问题的工具，更是一种思维方式。它教会我们如何分解复杂，如何寻找最优，如何在有限中创造无限。'
  },
  {
    date: '2024年2月10日',
    title: '开源的精神',
    content: '代码共享，智慧传承。开源不仅是技术，更是一种精神。在分享中成长，在协作中进步，这是技术社区最美的风景。'
  }
];
---

<BaseLayout title="技术 - 思想集" theme="tech">
  <TechBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">技术</h1>
    <p class="theme-subtitle">代码的矩阵，数据的流动，探索技术的无限可能</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #0a6f5d, #19fac6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.7;
    max-width: 500px;
    margin: 0 auto;
    color: #888;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(10, 111, 93, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(10, 111, 93, 0.2);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(10, 111, 93, 0.15);
    border-color: rgba(10, 111, 93, 0.4);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    display: block;
    color: #888;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, #0a6f5d, #19fac6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.85;
    color: #b0b0b0;
  }
</style>
