---
import BaseLayout from '../layouts/BaseLayout.astro';
import NatureBackground from '../components/backgrounds/NatureBackground.astro';

const thoughts = [
  {
    date: '2024年3月25日',
    title: '森林的呼吸',
    content: '走进森林，仿佛进入另一个世界。每一棵树都在诉说着时间的故事，每一片叶子都在演绎着生命的轮回。自然，是最好的老师。'
  },
  {
    date: '2024年2月20日',
    title: '溪流的智慧',
    content: '溪水潺潺，从不急躁。它知道，只要方向正确，终会抵达大海。人生亦是如此，不必焦虑，只需坚持向前。'
  },
  {
    date: '2024年1月10日',
    title: '四季的轮回',
    content: '春生夏长，秋收冬藏。自然教会我们，每个阶段都有其意义。不必强求，顺应自然的节奏，生命自有其韵律。'
  }
];
---

<BaseLayout title="自然 - 思想集" theme="nature">
  <NatureBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">自然</h1>
    <p class="theme-subtitle">翠绿的森林，飘落的树叶，感受大自然的宁静与智慧</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #2ECC71, #27AE60);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.8;
    max-width: 500px;
    margin: 0 auto;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(46, 204, 113, 0.3);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(46, 204, 113, 0.2);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    display: block;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #27AE60;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.9;
  }
</style>
