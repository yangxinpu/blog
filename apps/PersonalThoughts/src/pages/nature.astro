---
import BaseLayout from '../layouts/BaseLayout.astro';
import NatureBackground from '../components/backgrounds/NatureBackground.astro';

const thoughts = [
  {
    date: '2024年3月25日',
    title: '森林的呼吸',
    content: '走进森林，仿佛进入另一个世界。每一棵树都在诉说着时间的故事，每一片叶子都在演绎着生命的轮回。自然，是最好的老师。'
  },
  {
    date: '2024年2月20日',
    title: '溪流的智慧',
    content: '溪流不争，却能穿透岩石；水滴不大，却能汇成江海。自然的智慧，在于以柔克刚，以退为进。学会像水一样，才能行得更远。'
  },
  {
    date: '2024年1月15日',
    title: '四季的轮回',
    content: '春生夏长，秋收冬藏。自然遵循着自己的节奏，不急不躁。人生亦是如此，每个阶段都有其意义，不必强求，顺其自然。'
  }
];
---

<BaseLayout title="自然 - 思想集" theme="nature">
  <NatureBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">自然</h1>
    <p class="theme-subtitle">翠绿的森林，流动的溪水，感受自然的宁静与智慧</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #19fac6, #13d6aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.7;
    max-width: 500px;
    margin: 0 auto;
    color: #888;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(25, 250, 198, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(25, 250, 198, 0.2);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(25, 250, 198, 0.15);
    border-color: rgba(25, 250, 198, 0.4);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    display: block;
    color: #888;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, #19fac6, #13d6aa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.85;
    color: #b0b0b0;
  }
</style>
