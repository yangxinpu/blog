---
import BaseLayout from '../layouts/BaseLayout.astro';
import WarmBackground from '../components/backgrounds/WarmBackground.astro';

const thoughts = [
  {
    date: '2024年3月15日',
    title: '春日的暖阳',
    content: '阳光透过窗帘洒落，在地板上绘出温暖的光斑。这一刻，时间仿佛静止，只剩下宁静与美好。生活中的温暖时刻，往往就藏在这些不经意的瞬间里。'
  },
  {
    date: '2024年2月14日',
    title: '家的味道',
    content: '厨房里飘来熟悉的香气，是妈妈在准备晚餐。这种温暖，是世界上最珍贵的礼物。无论走多远，家的方向永远是最温暖的归途。'
  },
  {
    date: '2024年1月1日',
    title: '新年的第一缕阳光',
    content: '站在窗前迎接新年的第一缕阳光，心中充满希望。每一个新的开始，都值得我们以最温暖的心情去拥抱。愿这一年，温暖常在。'
  }
];
---

<BaseLayout title="温馨 - 思想集" theme="warm">
  <WarmBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">温馨</h1>
    <p class="theme-subtitle">温暖的阳光，柔和的光芒，记录生活中最温柔的时刻</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #FF6B6B, #FFE66D);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.8;
    max-width: 500px;
    margin: 0 auto;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(255, 107, 107, 0.2);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
    display: block;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #FF6B6B;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.9;
  }
</style>
