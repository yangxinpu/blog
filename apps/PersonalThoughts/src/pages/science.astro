---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScienceBackground from '../components/backgrounds/ScienceBackground.astro';

const thoughts = [
  {
    date: '2024年4月15日',
    title: '星空的召唤',
    content: '仰望星空，我们看到的不仅是光点，而是时间的旅行者。每一颗星星都在诉说着宇宙的故事，而我们，是这个故事的一部分。'
  },
  {
    date: '2024年3月20日',
    title: '原子的舞蹈',
    content: '万物皆由原子组成，原子在永恒地运动。我们身体里的每一个原子，都曾属于恒星，属于宇宙的各个角落。我们，就是星尘。'
  },
  {
    date: '2024年2月15日',
    title: '探索的意义',
    content: '科学不是答案的集合，而是提问的艺术。每一个发现都带来新的问题，每一次探索都开启新的旅程。未知，是最大的诱惑。'
  }
];
---

<BaseLayout title="科学 - 思想集" theme="science">
  <ScienceBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">科学</h1>
    <p class="theme-subtitle">浩瀚的星空，原子的轨迹，探索宇宙的奥秘</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #19fac6, #97fce4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.7;
    max-width: 500px;
    margin: 0 auto;
    color: #888;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(25, 250, 198, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(25, 250, 198, 0.2);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(25, 250, 198, 0.15);
    border-color: rgba(25, 250, 198, 0.4);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    display: block;
    color: #888;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, #19fac6, #97fce4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.85;
    color: #b0b0b0;
  }
</style>
