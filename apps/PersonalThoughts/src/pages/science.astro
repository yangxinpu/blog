---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScienceBackground from '../components/backgrounds/ScienceBackground.astro';

const thoughts = [
  {
    date: '2024年4月15日',
    title: '星空的召唤',
    content: '仰望星空，我们看到的不仅是光点，而是时间的旅行者。每一颗星星都在诉说着宇宙的故事，而我们，是这个故事的一部分。'
  },
  {
    date: '2024年3月20日',
    title: '原子的舞蹈',
    content: '万物皆由原子组成，而原子内部是一个空旷的世界。我们看似坚实的存在，实际上是能量的振动。科学，让我们重新认识自己。'
  },
  {
    date: '2024年2月15日',
    title: '未知的边界',
    content: '每解开一个谜题，就会发现更多未解之谜。科学的魅力在于，它永远指向更远的地方。未知，是探索的最大动力。'
  }
];
---

<BaseLayout title="科学 - 思想集" theme="science">
  <ScienceBackground slot="background" />
  
  <div class="theme-header">
    <h1 class="theme-title">科学</h1>
    <p class="theme-subtitle">浩瀚的星空，原子的轨迹，探索宇宙的奥秘与真理</p>
  </div>
  
  <div class="thoughts-container">
    {thoughts.map((thought) => (
      <article class="thought-card">
        <time class="thought-date">{thought.date}</time>
        <h2 class="thought-title">{thought.title}</h2>
        <p class="thought-content">{thought.content}</p>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .theme-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .theme-title {
    font-size: 3.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #7C4DFF, #64FFDA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 0 40px rgba(124, 77, 255, 0.5);
  }

  .theme-subtitle {
    font-size: 1.1rem;
    opacity: 0.8;
    max-width: 500px;
    margin: 0 auto;
  }

  .thoughts-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 800px;
    width: 100%;
  }

  .thought-card {
    background: rgba(13, 13, 26, 0.7);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(124, 77, 255, 0.3);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .thought-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(124, 77, 255, 0.2);
    border-color: rgba(124, 77, 255, 0.5);
  }

  .thought-date {
    font-size: 0.875rem;
    opacity: 0.6;
    margin-bottom: 0.5rem;
    display: block;
  }

  .thought-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, #7C4DFF, #64FFDA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .thought-content {
    font-size: 1rem;
    line-height: 1.8;
    opacity: 0.9;
  }
</style>
