---
interface Props {
  title: string;
  theme?: 'nature' | 'life' | 'resilience' | 'tech' | 'science';
}

const { title, theme = 'nature' } = Astro.props;

const themeColors = {
  nature: { primary: '#19fac6', secondary: '#13d6aa', bg: '#0a1a15' },
  life: { primary: '#13d6aa', secondary: '#0ea387', bg: '#0a1512' },
  resilience: { primary: '#0ea387', secondary: '#0a6f5d', bg: '#0a0f0e' },
  tech: { primary: '#0a6f5d', secondary: '#19fac6', bg: '#0a192f' },
  science: { primary: '#19fac6', secondary: '#97fce4', bg: '#0d0d1a' },
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="个人感想 - 思想的栖息地" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body data-theme={theme}>
    <div class="background-container">
      <slot name="background" />
    </div>
    <nav class="nav">
      <a href="/" class="logo">思想集</a>
      <div class="nav-links">
        <a href="/nature">自然</a>
        <a href="/life">生命</a>
        <a href="/resilience">坚韧</a>
        <a href="/tech">技术</a>
        <a href="/science">科学</a>
      </div>
    </nav>
    <main class="main">
      <slot />
    </main>
    <footer class="footer">
      <p>© 2024 个人感想集 · 思想的栖息地</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    color: #e0e0e0;
    background: #0a0a0a;
  }

  body[data-theme='nature'] { color: #e0e0e0; }
  body[data-theme='life'] { color: #e0e0e0; }
  body[data-theme='resilience'] { color: #ecf0f1; }
  body[data-theme='tech'] { color: #e6f1ff; }
  body[data-theme='science'] { color: #e0e0e0; }
</style>

<style>
  .background-container {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(25, 250, 198, 0.1);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    color: #19fac6;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    text-decoration: none;
    color: #888;
    transition: color 0.3s ease;
    font-size: 0.95rem;
  }

  .nav-links a:hover {
    color: #19fac6;
  }

  .main {
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .footer {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
    color: #666;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .nav {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .main {
      padding: 8rem 1rem 2rem;
    }
  }
</style>
