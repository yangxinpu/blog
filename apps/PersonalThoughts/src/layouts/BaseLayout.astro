---
interface Props {
  title: string;
  theme?: 'nature' | 'resilience' | 'tech' | 'science';
}

const { title, theme = 'nature' } = Astro.props;

const themeColors = {
  nature: { primary: '#19fac6', secondary: '#13d6aa', bg: '#0a1a15' },
  resilience: { primary: '#0ea387', secondary: '#0a6f5d', bg: '#0a0f0e' },
  tech: { primary: '#0a6f5d', secondary: '#19fac6', bg: '#0a192f' },
  science: { primary: '#19fac6', secondary: '#97fce4', bg: '#0d0d1a' },
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NaiLuo - 个人感想" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body data-theme={theme}>
    <div class="background-container">
      <slot name="background" />
    </div>
    <nav class="nav">
      <div class="nav-left"></div>
      <div class="nav-center">
        <a href="/nature" class="nav-link">
          <span class="nav-link-text">自然</span>
          <span class="nav-link-bg"></span>
          <span class="nav-link-glow"></span>
        </a>
        <a href="/resilience" class="nav-link">
          <span class="nav-link-text">坚韧</span>
          <span class="nav-link-bg"></span>
          <span class="nav-link-glow"></span>
        </a>
        <a href="/tech" class="nav-link">
          <span class="nav-link-text">技术</span>
          <span class="nav-link-bg"></span>
          <span class="nav-link-glow"></span>
        </a>
        <a href="/science" class="nav-link">
          <span class="nav-link-text">科学</span>
          <span class="nav-link-bg"></span>
          <span class="nav-link-glow"></span>
        </a>
      </div>
      <div class="nav-right">
        <a href="/" class="nav-btn" title="首页">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span>首页</span>
        </a>
        <a href="https://nailuo-blog.vercel.app/" class="nav-btn" target="_blank" rel="noopener noreferrer" title="博客">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
          </svg>
          <span>博客</span>
        </a>
        <a href="https://github.com" class="nav-btn" target="_blank" rel="noopener noreferrer" title="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    </nav>
    <main class="main">
      <slot />
    </main>
    <footer class="footer">
      <p>© 2026 NaiLuo - 个人感想</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    color: #e0e0e0;
    background: #0a0a0a;
  }

  body[data-theme='nature'] { color: #e0e0e0; }
  body[data-theme='resilience'] { color: #ecf0f1; }
  body[data-theme='tech'] { color: #e6f1ff; }
  body[data-theme='science'] { color: #e0e0e0; }
</style>

<style>
  .background-container {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-left {
    flex: 1;
  }

  .nav-center {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    color: #ffffff;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  .nav-link-text {
    position: relative;
    z-index: 3;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
  }

  .nav-link-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(25, 250, 198, 0.1), rgba(19, 214, 170, 0.05));
    border-radius: 12px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  .nav-link-glow {
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, #19fac6, #13d6aa, #0ea387);
    border-radius: 14px;
    opacity: 0;
    filter: blur(8px);
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  .nav-link:hover .nav-link-text {
    color: #19fac6;
    text-shadow: 0 0 20px rgba(25, 250, 198, 0.5);
  }

  .nav-link:hover .nav-link-bg {
    transform: scaleX(1);
  }

  .nav-link:hover .nav-link-glow {
    opacity: 0.4;
    animation: glow-pulse 1.5s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% {
      opacity: 0.4;
      filter: blur(8px);
    }
    50% {
      opacity: 0.6;
      filter: blur(12px);
    }
  }

  .nav-link:active {
    transform: translateY(0) scale(0.98);
  }

  .nav-right {
    flex: 1;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: flex-end;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #ffffff;
    transition: all 0.3s ease;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.9rem;
  }

  .nav-btn:hover {
    color: #19fac6;
    background: rgba(25, 250, 198, 0.1);
    border-color: rgba(25, 250, 198, 0.3);
  }

  .nav-btn svg {
    flex-shrink: 0;
  }

  .main {
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .footer {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
    color: #666;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .nav {
      flex-wrap: wrap;
      padding: 1rem;
      gap: 1rem;
    }

    .nav-left {
      display: none;
    }

    .nav-center {
      order: 2;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .nav-link {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }

    .nav-right {
      order: 1;
      justify-content: center;
      gap: 0.5rem;
    }

    .nav-btn span {
      display: none;
    }

    .nav-btn {
      padding: 0.5rem;
    }

    .main {
      padding: 8rem 1rem 2rem;
    }
  }
</style>
